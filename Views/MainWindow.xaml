<Window x:Class="UsbMediaManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="USB Media Manager" Height="640" Width="960"
        FlowDirection="RightToLeft" FontFamily="Segoe UI, Tahoma">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- وضعیت -->
        <Border Grid.Row="0" Background="#F0F4FF" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="{Binding StatusText}" FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <!-- سرچ مشتری -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Width="260" Text="{Binding CustomerSearch, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="6"/>
            <Button Content="سرچ مشتری" Command="{Binding SearchCustomersCommand}" Margin="8,0,0,0" Padding="12,6"/>
            <Button Content="افزودن فیلم/سریال" Command="{Binding AddMediaFromTmdbCommand}" Margin="8,0,0,0" Padding="12,6"/>
            <Button Content="کیا این سریال رو دارن؟" Command="{Binding OpenSeriesSearchCommand}" Margin="8,0,0,0" Padding="12,6"/>
        </StackPanel>

        <!-- محتوا -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- نتایج سرچ مشتری -->
            <GroupBox Grid.Column="0" Header="مشتری‌ها" Margin="0,0,8,0">
                <ListView ItemsSource="{Binding SearchResults}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Drives.Count, StringFormat='تعداد فلش: {0}'}"
                                           Foreground="Gray" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

            <!-- لیست فیلم/سریال فلش فعلی -->
            <GroupBox Grid.Column="1" Header="فیلم/سریال‌های فلش فعلی" Margin="8,0,0,0">
                <ListView ItemsSource="{Binding ActiveDriveMedia}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <Image Source="{Binding PosterUrl}" Width="46" Height="69" Margin="0,0,8,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Year}" Foreground="Gray" FontSize="12"/>
                                    <TextBlock Text="{Binding Type}" Foreground="#4a6" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>
        </Grid>

        <TextBlock Grid.Row="3" Text="USB Media Manager — v1.0" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>