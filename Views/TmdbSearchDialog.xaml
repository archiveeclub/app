<Window x:Class="UsbMediaManager.Views.TmdbSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سرچ فیلم/سریال (TMDB)" Height="520" Width="560"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        FontFamily="Segoe UI, Tahoma">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="QueryBox" Width="360" Padding="6"/>
            <Button Content="سرچ" Click="OnSearch" Padding="14,6" Margin="8,0,0,0" IsDefault="True"/>
        </StackPanel>
        <ListView x:Name="ResultsList" Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Image Source="{Binding PosterUrl}" Width="46" Height="69" Margin="0,0,8,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Year}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding Type}" Foreground="#4a6" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
            <Button Content="انتخاب" Width="90" Padding="6" Click="OnSelect"/>
            <Button Content="انصراف" Width="90" Padding="6" Margin="8,0,0,0" Click="OnCancel" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
using System.Windows;
using UsbMediaManager.Services;

namespace UsbMediaManager.Views;

public partial class TmdbSearchDialog : Window
{
    private readonly TmdbService _tmdb;
    public TmdbResult? SelectedResult { get; private set; }

    public TmdbSearchDialog(TmdbService tmdb)
    {
        InitializeComponent();
        _tmdb = tmdb;
    }

    private async void OnSearch(object sender, RoutedEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(QueryBox.Text)) return;
        ResultsList.ItemsSource = await _tmdb.SearchAsync(QueryBox.Text.Trim());
    }

    private void OnSelect(object sender, RoutedEventArgs e)
    {
        if (ResultsList.SelectedItem is TmdbResult r) { SelectedResult = r; DialogResult = true; }
        else MessageBox.Show("یه مورد رو انتخاب کن.");
    }

    private void OnCancel(object sender, RoutedEventArgs e) => DialogResult = false;
}